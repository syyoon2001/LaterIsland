rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can only read/write documents under their own
    // /users/{uid} subtree (items, categories, tags). No cross-user access.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
