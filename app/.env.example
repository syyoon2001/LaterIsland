# Vite provides build-mode flags automatically — no custom variable is
# needed for these. Documented here for reference:
#
#   import.meta.env.DEV   -> true when running `npm run dev`, false in production builds
#   import.meta.env.PROD  -> the inverse of DEV
#   import.meta.env.MODE  -> 'development' | 'production' (set by the dev/build command)
#
# src/App.tsx uses import.meta.env.DEV to gate rendering of the
# dev/test-only SimulationPanel (src/components/SimulationPanel.tsx), so it
# and its "무작위 항목 5개 생성" / "전체 항목 삭제" test buttons are excluded
# from production builds (`npm run build`) via dead-code elimination.

# Firebase project config (src/lib/firebase.ts). Copy this file to .env.local
# and fill in real values from the Firebase console — never commit the real
# values (.env.local is gitignored).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
