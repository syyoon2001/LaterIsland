rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Each signed-in user can only read/write image files under their own
    // /images/{uid} subtree (uploaded via the Add/Edit content form). No
    // cross-user access.
    match /images/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
